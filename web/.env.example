# ========================================================================
# Generator Web 环境变量配置示例
# ========================================================================
# 
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 根据实际情况修改配置值
# 3. .env 文件已添加到 .gitignore，不会被提交到版本控制系统
#
# ========================================================================

# 数据库配置
# 数据库用户名（可选，默认：root）
DB_USERNAME=root

# 数据库密码（必需，请修改为实际密码）
DB_PASSWORD=your_password_here

# 是否使用 SSL 连接数据库（可选，默认：false）
# 生产环境建议设置为 true 以提高安全性
DB_USE_SSL=false

# ========================================================================
# 其他可选配置
# ========================================================================

# JVM 参数（可选）
# JAVA_OPTS=-Xmx512m -Xms256m

# 应用端口（可选，默认：8081）
# SERVER_PORT=8081